{{> navbar}}
<main>
    <h1>Add a ChillSpot</h1>
    <ul class="errorList" id="errors">
        {{#if errors}}
        {{#each errors}}
        <li>{{this}}</li>
        {{/each}}
        {{/if}}
    </ul>

    <form id="addLocationForm" method="POST" action="/location" enctype="multipart/form-data">
        <label for="locName">Name: </label>
        <input type="text" id="locName" name="locName" />
        <br />

        <label for="locAddress">Address: </label>
        <input type="text" id="locAddress" name="locAddress" />
        <br />

        <label for="zip">ZIP Code: </label>
        <input type="text" id="zipcode" name="zipcode" maxlength="5" />
        <br />

        <label for="lat">Latitude: </label>
        <input type="text" id="lat" name="lat" />
        <br />

        <label for="lng">Latitude: </label>
        <input type="text" id="lng" name="lng" />
        <br />

        <label for="locTags">Tags:</label>
        <input type="text" id="locTags" list="tagsForNewLoc" />
        <datalist id="tagsForNewLoc">
            {{#each allowedTags}}
            <option value="{{this}}"></option>
            {{/each}}
        </datalist>
        <br />

        <label for="pics">Location Pictures: </label>
        <input type="file" id="pics" name="pics" accept="image/jpeg,image/png,image/webp" multiple />
        <br />

        <button type="submit">Add ChillSpot</button>

    </form>
</main>