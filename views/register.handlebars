{{!
Handlebars Variables:
errors: array for errors that occur during registration
}}
{{> navbar}}
<div class="page-content">
  <div class="card">
    <h1>Create an Account</h1>
    <ul class="errorList" id="errors">
      {{#if errors}}
        {{#each errors}}
          <li>{{this}}</li>
        {{/each}}
      {{/if}}
    </ul>
    <form id="register-form" name="register-form" method="POST" enctype="multipart/form-data" action="/register">
      <label for="firstName">First Name</label>
      <input type="text" id="firstName" name="firstName" value="{{currForm.firstName}}" />

      <label for="lastName">Last Name</label>
      <input type="text" id="lastName" name="lastName" value="{{currForm.lastName}}" />

      <label for="username">Username</label>
      <input type="text" id="username" name="username" value="{{currForm.username}}" />

      <label for="age">Age</label>
      <input type="number" id="age" name="age" min="13" max="120" value="{{currForm.age}}" />

      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="{{currForm.email}}" />

      <label for="password">Password</label>
      <input type="password" id="password" name="password" />

      <label for="confirmPass">Confirm Password</label>
      <input type="password" id="confirmPass" name="confirmPass" />

      <label for="profilePic">Profile Picture (optional)</label>
      <input type="file" id="profilePic" name="profilePic" accept="image/jpeg,image/png,image/webp" />

      <label for="adminSecret">Admin Secret (optional)</label>
      <input type="text" id="adminSecret" name="adminSecret" />

      <input type="submit" id="registerButton" name="registerButton" value="Register" />
    </form>
  </div>
</div>
{{> footer}}
