{{!
Handlebars Variables:
firstName
lastName
username
email
profilePic
}}
{{> navbar}}
<main class="profileContent">
  <section class="editProfileSecion">
    <h1>Edit Profile</h1>
  <form id="profileForm" method="POST" action="/user/profile" enctype="multipart/form-data">
    <label for="firstName">First Name: </label>
    <input type="text" id="firstName" name="firstName" value="{{firstName}}" />
    <br />
    <label for="lastName">Last Name: </label>
    <input type="text" id="lastName" name="lastName" value="{{lastName}}" />
    <br />
    <label for="username">Username: </label>
    <input type="text" id="username" name="username" value="{{username}}" />
    <br />

    <label for="email">Email: </label>
    <input type="email" id="email" name="email" value="{{email}}" />
    <br />

    <label for="password">Current Password: </label>
    <input type="password" id="password" name="password" />
    <br />
    <label for="newPassword">New Password: </label>
    <input type="password" id="newPassword" name="newPassword" />
    <br />
    <label for="confirmNewPassword">Confirm New Password: </label>
    <input type="password" id="confirmNewPassword" name="confirmNewPassword" />
    <br />

    <div class="currentProfilePic">
      <img id="profilePic" class="originalProfilePic" src="{{profilePic}}" alt="{{username}} profile picture"/>
    </div>
    <label for="newProfilePic">Update Profile Picture: </label>
    <input type="file" id="newProfilePic" name="newProfilePic" accept="image/png,image/jpeg,image/webp" />
    <br />

    <button type="submit">Update Profile</button>
  </form>
  </section>
  <section>
    <h2>Visited Locations</h2>
    {{#if visited.length}}
    <ul>
      {{#each visited}}
        <li><a href="/location?loc_name={{loc_name}}">{{loc_name}}</a></li>
      {{/each}}
    </ul>
    {{else}}
    <p>No locations visited yet.</p>
    {{/if}}
  </section>
  <section>
    <h2>Friends</h2>
    {{#if friends.length}}
      <ul>
      {{#each friends}}
        <li>{{this}}</li>
      {{/each}}
      </ul>
    {{else}}
    <p>No friends yet.</p>
    {{/if}}
    <form id="addFriendForm" method="POST" action="/user/friends">
      <label for="friendUsername">Add Friend by Username:</label>
      <input type="text" id="friendUsername" name="friendUsername">

      <button type="submit">Add Friend</button>
    </form>
  </section>
  <section>
    <h2>Public Lists</h2>
    {{#if lists.length}}
    <ul>
      {{#each lists}}
        <li><a href="/publiclists/{{this}}">{{this}}</a></li>
      {{/each}}
    </ul>
    {{else}}
    <p>No public lists created yet.</p>
    {{/if}}
  </section>
  <section>
    <h2>Achievements</h2>
    {{#if achievements.length}}
      <ul>
      {{#each achievements}}
        <li>{{this}}</li>
      {{/each}}
      </ul>
    {{else}}
    <p>No achievements yet.</p>
    {{/if}}
  </section>
</main>
{{> footer}}