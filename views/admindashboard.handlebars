<!--
    Handlebars Variable:
        reports array (contains report objects)
        each report has: id, content, type, reason
        isLocation, isComment, isReview,
-->
{{> navbar}}
<div class="page-content">
  <h1>Admin Dashboard</h1>
  {{#if reports.length}}
  <ul style="list-style:none;padding:0;">
    {{#each reports}}
    <li class="report">
      <p><strong>Type:</strong> {{type}}</p>
      <p><strong>Report:</strong> {{content}}</p>
      {{#if isLocation}}
      <button class="btn-danger" onclick="deleteLocation('{{item_id}}')">Delete Location</button>
      {{/if}}
      {{#if isComment}}
      <button class="btn-danger" onclick="deleteComment('{{item_id}}')">Delete Comment</button>
      {{/if}}
      {{#if isReview}}
      <button class="btn-danger" onclick="deleteReview('{{item_id}}')">Delete Review</button>
      {{/if}}
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p>No reports to review.</p>
  {{/if}}
</div>
{{> footer}}