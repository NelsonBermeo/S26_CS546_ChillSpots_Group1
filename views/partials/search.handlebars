<div class="searchbar">
    <h2>Location Search</h2>
    <form action="/location" method="GET" class="search-locations">
        <label for="query">Looking for somewhere? Try to find it here!</label>
        <input
            type="text"
            id="query"
            name="query"
            placeholder="Search for locations here..."
            value="{{query}}"/>
    </form>
</div>